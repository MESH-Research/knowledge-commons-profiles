      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19}
    },
    {
      "type": "row",
      "id": 400,
      "title": "Redis",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 401,
      "title": "Memory used (bytes)",
      "targets": [
        {"expr": "redis_memory_used_bytes", "legendFormat": "{{instance}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28}
    },
    {
      "type": "timeseries",
      "id": 402,
      "title": "Connected clients",
      "targets": [
        {"expr": "redis_connected_clients", "legendFormat": "{{instance}}", "refId": "A"}
