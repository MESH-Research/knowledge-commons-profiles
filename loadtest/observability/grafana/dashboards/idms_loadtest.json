    },
    {
      "type": "timeseries",
      "id": 501,
      "title": "CPU usage (%)",
      "targets": [
        {"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "legendFormat": "{{instance}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37}
    },
    {
      "type": "timeseries",
      "id": 502,
      "title": "Memory used (%)",
      "targets": [
        {"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "{{instance}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37}
    }
