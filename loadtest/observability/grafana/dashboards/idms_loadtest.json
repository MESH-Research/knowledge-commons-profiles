  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Locust",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 101,
      "title": "Locust requests/sec by name",
      "targets": [
        {"expr": "sum by (name) (rate(locust_requests_total[1m]))", "legendFormat": "{{name}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1}
    },
    {
      "type": "timeseries",
      "id": 102,
      "title": "Locust p95 response time (ms) by name",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, name) (rate(locust_requests_response_time_bucket[1m])))", "legendFormat": "p95 {{name}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1}
    },
    {
      "type": "row",
      "id": 200,
      "title": "Django (django-prometheus)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 201,
      "title": "HTTP requests/sec by view",
      "targets": [
        {"expr": "sum by (view) (rate(django_http_requests_total_by_view_transport_method_total[1m]))", "legendFormat": "{{view}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}
    },
    {
      "type": "timeseries",
      "id": 202,
      "title": "p95 response latency by view (s)",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, view) (rate(django_http_responses_total_by_status_view_method_total[1m])))", "legendFormat": "{{view}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}
    },
    {
      "type": "row",
      "id": 300,
      "title": "Postgres",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 301,
      "title": "Active connections",
      "targets": [
        {"expr": "sum by (state) (pg_stat_activity_count)", "legendFormat": "{{state}}", "refId": "A"}
