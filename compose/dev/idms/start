#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

# The IDMS service runs the broker endpoints as async views under ASGI.
# Force the dev IDMS settings even when the shared env file sets
# DJANGO_SETTINGS_MODULE=config.settings.dev for the main app.
export DJANGO_SETTINGS_MODULE=config.settings.idms_dev

echo "Running uvicorn (IDMS async broker, dev)..."
exec uv run uvicorn config.asgi:application \
    --host 0.0.0.0 \
    --port 8000 \
    --proxy-headers \
    --forwarded-allow-ips='*' \
    --workers "${UVICORN_WORKERS:-2}"
