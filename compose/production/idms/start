#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

# The IDMS service runs the broker endpoints as async views under ASGI.
# Force the IDMS settings even when the shared env file sets
# DJANGO_SETTINGS_MODULE=config.settings.production for the main app.
export DJANGO_SETTINGS_MODULE=config.settings.idms

echo "Running uvicorn (IDMS async broker)..."
# --proxy-headers / --forwarded-allow-ips: trust the X-Forwarded-* headers set
# by Traefik (TLS terminates upstream), so Django sees the real scheme/host.
# The container is only reachable from the load balancer, never directly.
# --workers: each is its own event loop; size ~= task vCPUs and scale ECS
# tasks horizontally for more capacity.
exec uv run uvicorn config.asgi:application \
    --host 0.0.0.0 \
    --port 8000 \
    --proxy-headers \
    --forwarded-allow-ips='*' \
    --workers "${UVICORN_WORKERS:-2}"
