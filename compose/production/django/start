#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

echo "Collecting static files"
uv run python /app/manage.py collectstatic --noinput

echo "Running gunicorn..."
exec uv run gunicorn config.wsgi \
    --bind 0.0.0.0:5000 \
    --chdir=/app \
    --workers "${GUNICORN_WORKERS:-5}" \
    --threads "${GUNICORN_THREADS:-8}" \
    --worker-class gthread \
    --worker-tmp-dir /dev/shm \
    --timeout 15 \
    --graceful-timeout 15 \
    --keep-alive 5 \
    --max-requests 1000 \
    --max-requests-jitter 100 \
    --access-logfile -
