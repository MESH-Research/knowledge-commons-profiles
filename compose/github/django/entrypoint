#!/bin/bash

set -o errexit
set -o pipefail
set -o nounset

if [ -z "${POSTGRES_USER}" ]; then
    base_postgres_image_default_user='postgres'
    export POSTGRES_USER="${base_postgres_image_default_user}"
fi
export DATABASE_URL="postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

wait-for-it "${POSTGRES_HOST}:${POSTGRES_PORT}" -t 30

>&2 echo 'PostgreSQL is available'

echo 'Syncing uv environment...'
# Throttle parallel wheel downloads so the container's DNS resolver
# doesn't drop lookups under load (EAI_AGAIN). Bump the per-request
# timeout while we're at it.
UV_CONCURRENT_DOWNLOADS=4 UV_HTTP_TIMEOUT=120 \
  uv sync --frozen --no-install-project --no-default-groups --group "${BUILD_ENV}"

exec "$@"
